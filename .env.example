# .env.example file for noti-mcp environment variables

# Notification API Configuration
NOTI_API_URL=https://your-real-api-server.com/api/v1/notification
NOTI_API_TOKEN=your-real-api-token-here
# Application Settings
SERVER_PORT=8080
LOGGING_LEVEL=com.example.notimcp=DEBUG

# JWT Settings (if needed)
JWT_SECRET=your-jwt-secret-here